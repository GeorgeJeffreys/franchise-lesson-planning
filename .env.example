# Copy to .env.local and fill in. Never commit real values.

# Supabase — client-safe. These are exposed to the browser by design and are
# used by the auth'd server/browser clients, which honor Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by admin/seed scripts AND the curriculum import (writes +
# cached reference reads) — it BYPASSES RLS, so it must never be exposed to the
# browser. See src/lib/supabase/admin.ts for the (reference-data only) read use.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Shared secret the n8n folder-watch sends as `x-curriculum-secret`
# to POST /api/curriculum/import. The in-app upload path uses the session instead.
CURRICULUM_IMPORT_SECRET=

# Anthropic (Claude) API keys — server-only, never NEXT_PUBLIC_*. Split into two
# keys so cost is tracked per function in the Anthropic Console. They are NOT
# interchangeable; each function reads ONLY its own key (see src/lib/anthropic.ts).
# A missing key fails loudly at first use (503) rather than silently falling back.
# SMARTT objective checking only (src/lib/ai/check-objective.ts).
ANTHROPIC_API_KEY_SMARTT=
# Resource generation only (src/lib/ai/generate-resource.ts).
ANTHROPIC_API_KEY_RESOURCES=

# Microsoft (Azure) SSO credentials for Supabase Auth. Configured on the
# Supabase project / supabase config.toml; listed here for local reference.
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_AZURE_SECRET=

# ── Dev/preview-only test-user switcher (TEST MODE bar) ───────────────────────
# SECURITY-SENSITIVE: the bar signs in as a dedicated per-tester PERSONA so an
# eligible tester can view the app as that teacher (faithful, RLS-scoped, owning
# only that teacher's plans). All server-only; never NEXT_PUBLIC_*. The bar/route
# do nothing unless ENABLE_TEST_IMPERSONATION=true AND VERCEL_ENV is not
# "production" AND the caller is eligible (see below).
# In production the bar stays off unless ALLOW_IMPERSONATION_IN_PRODUCTION below
# is ALSO "true" (testers-only deployments). Leave both unset for real users.
ENABLE_TEST_IMPERSONATION=
# Production opt-in: with VERCEL_ENV="production", the bar/route work only if this
# is "true" (AND ENABLE_TEST_IMPERSONATION="true" AND the caller is eligible).
# Ignored outside production. REMOVE this before real (non-tester) users are on production.
ALLOW_IMPERSONATION_IN_PRODUCTION=
# Eligibility to USE the bar = profiles.can_impersonate OR real admin OR this
# comma-separated auth-UID allowlist (kept as a fallback so existing access is
# unbroken). Onboarding a tester is otherwise a one-row UPDATE (can_impersonate).
# NOTE: persona ENUMERATION reads auth.users via a security-definer RPC that cannot
# see this env var, so to populate the picker the caller must be a real admin or
# have can_impersonate=true (set it on your own profile once if you rely on this).
TEST_IMPERSONATION_ALLOWED_UIDS=
# The single shared password every seeded persona signs in with (email comes from
# the persona row, server-side). Create each persona auth user in the Supabase
# dashboard with this exact password + auto-confirmed, then seed profiles via
# supabase/admin/seed_test_personas.sql. Server-only; never NEXT_PUBLIC_*, never
# returned to the client or logged.
TEST_PERSONA_PASSWORD=
