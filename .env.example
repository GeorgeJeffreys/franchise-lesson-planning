# Copy to .env.local and fill in. Never commit real values.

# Supabase — client-safe. These are exposed to the browser by design and are
# used by the auth'd server/browser clients, which honor Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used ONLY by admin/seed scripts — it BYPASSES RLS, so it must
# never be imported into a user-facing request or exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Auth is email + password on the teacher's Alsama email (Supabase Auth). There
# are no SSO provider secrets to configure. Accounts are created by admin invite
# (Supabase dashboard → Authentication → Users → Invite); public sign-up is off.
#
# Invite + password-reset emails: the built-in Supabase mailer is heavily
# rate-limited and test-only. Production custom SMTP (Site URL, redirect
# allowlist, SMTP creds) is configured in the Supabase dashboard, not here.
