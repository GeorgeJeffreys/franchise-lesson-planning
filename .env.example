# Copy to .env.local and fill in. Never commit real values.

# Supabase — client-safe. These are exposed to the browser by design and are
# used by the auth'd server/browser clients, which honor Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by admin/seed scripts AND the curriculum import (writes +
# cached reference reads) — it BYPASSES RLS, so it must never be exposed to the
# browser. See src/lib/supabase/admin.ts for the (reference-data only) read use.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Shared secret the n8n folder-watch sends as `x-curriculum-secret`
# to POST /api/curriculum/import. The in-app upload path uses the session instead.
CURRICULUM_IMPORT_SECRET=

# Microsoft (Azure) SSO credentials for Supabase Auth. Configured on the
# Supabase project / supabase config.toml; listed here for local reference.
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_AZURE_SECRET=

# ── Dev/preview-only test-user switcher (TEST MODE bar) ───────────────────────
# SECURITY-SENSITIVE: the bar mints real Supabase sessions so an admin can view
# the app as a seeded test user (faithful, RLS-scoped). All server-only; never
# NEXT_PUBLIC_*. The bar/route do nothing unless ENABLE_TEST_IMPERSONATION=true
# AND VERCEL_ENV is not "production" AND the real user is on the allowlist.
# Leave ENABLE_TEST_IMPERSONATION unset/false in production.
ENABLE_TEST_IMPERSONATION=
# Comma-separated real-admin auth UIDs allowed to impersonate.
TEST_IMPERSONATION_ALLOWED_UIDS=
# The three pre-configured target users the role keys map to.
TEST_USER_TEACHER_ID=
TEST_USER_COORDINATOR_ID=
TEST_USER_ADMIN_ID=
